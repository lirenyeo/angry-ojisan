# Angry Selfie Mode generates the angry face two ways:
#
# Primary — Gemini cuts your face out of the photo and makes an angry version.
GEMINI_API_KEY=AIza...
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Quotes (and the fallback canvas filter when Gemini is unavailable) use Claude.
ANTHROPIC_API_KEY=sk-ant-...

# With neither key, the game still plays; selfies get a heuristic rage filter.

# Optional
PORT=3000
